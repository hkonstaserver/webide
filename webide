    function ToolBar() {
    
        var wc;
    
        var flink = "<input value='"+fname+"' id='cfile' size='14' style='font-size: 18px; background-color: SkyBlue; border-radius: 6px;' >";
        
        wc =      "<h1>&nbsp;&nbsp;&nbsp; WebIDE :&nbsp;"; wc=wc+flink+"&nbsp;";
        wc = wc + "<input type=\"file\" name=\"myfile\" id=\"filename\" style=\"display:none\" onchange=\"getFile(event);\">&nbsp;&nbsp;";
        
        wc = wc + "<select id='fsize' onchange=\"fontSize();\"><option value='10'>10</option><option value='12'>12</option><option selected='selected'>14</option>";
        wc = wc + "<option value='16'>16</option><option value='18'>18</option><option value='20'>20</option></select>&nbsp;&nbsp;";
    
        wc = wc + "<button style=\"font-size: 16px; border-radius: 4px;\" onclick=\"New();\">NEW</button>&nbsp;"; 
        wc = wc + "<button style=\"font-size: 16px; border-radius: 4px;\" onclick=\"document.getElementById('filename').click();\">IMPORT</button>&nbsp;";
        wc = wc + "<button style=\"font-size: 16px; border-radius: 4px;\" onclick=\"exportFile();\">EXPORT</button>&nbsp;"; 
        wc = wc + "<button style=\"font-size: 16px; border-radius: 4px;\" onclick=\"saveSession();\">SAVE</button>&nbsp;"; 
        wc = wc + "<button style=\"font-size: 16px; border-radius: 4px;\" onclick=\"Preview();\">PREVIEW</button>";
        
        wc = wc + "&nbsp;[F12:dev] <small>(built using ACE.js)</small></h1>";
        
        document.getElementById("toolbar").innerHTML = wc;
        
    }


    function fontSize() {
    
        var e = document.getElementById("fsize");
        var size = e.options[e.selectedIndex].value + "px";
    
        document.getElementById('editor').style.fontSize=size;
    
    }

        
    function saveFile(filename, text) {
        
        var element = document.createElement('a');
        
        element.setAttribute('href', 'data:text/plain;charset=utf-8,' + encodeURIComponent(text));
        element.setAttribute('download', filename);

        element.style.display = 'none';
        document.body.appendChild(element);

        element.click();

        document.body.removeChild(element);
    }


    function exportFile() {
    
        fname = document.getElementById('cfile').value;    
        saveFile(fname,editor.session.getValue());
    
    }
    
    
    function buildSession() {
    
        var sname = document.getElementById('cfile').value;    
        document.title = "$"+sname;
     
        // use base64 not to loose tags
        document.getElementById("usercode").innerHTML = btoa(editor.session.getValue());
                
    }
    
    
    function saveSession() {
    
        buildSession();
        saveFile("$"+fname,document.documentElement.outerHTML);
        
    }
        
        
    function New() {
      
        var ucode = document.getElementById("usercode").innerHTML;
        var uedit = editor.session.getValue();
        
        document.getElementById("usercode").innerHTML="";
        editor.session.setValue("");
        window.open(window.location.href);
    
        document.getElementById("usercode").innerHTML = ucode;
        editor.session.setValue(uedit);
        
    }
    
    
    function Preview() {
    
        buildSession();
    
        var data = editor.session.getValue();
        
        win = window.open("","_blank");    
        win.document.write(data); 
        win.document.close();
        
    }
    

    function getFile(event) {
        var fileList = event.target.files;

        for(var i=0; i < fileList.length; i++ ) {
            loadAsText(fileList[i]);
        }
    }


    function loadAsText(theFile) {
    
        var reader = new FileReader();
        
        reader.onload = function(loadedEvent) {                
            editor.session.setValue(this.result);            
        }
        
        reader.readAsText(theFile);
        fname = theFile.name;
        document.title = "$"+fname;
        ToolBar();
    }    


    function Viewer() {
    
        var data = atob(document.getElementById("usercode").innerHTML);

        document.getElementsByTagName("head")[0].innerHTML = "";
        document.getElementsByTagName("body")[0].innerHTML = "";        
        document.write(data);
        
    }
    
    
	// F5 Key handler for Preview
	document.onkeydown = function(e) {
        e = e || window.event;
		
        switch(e.which || e.keyCode) {
	        case 116: // F5
			    Preview();
            break;

            default: return; // exit this handler for other keys
        }
        e.preventDefault(); // prevent the default action (scroll / move caret)
    };
		
		
	// Warning before closing/leaving the page
    window.onbeforeunload = function() {
        return "Do you really want to leave our brilliant application?";
    };

	// Check if runs on mobile
    function isMobile() {
        return (typeof window.orientation !== "undefined") || (navigator.userAgent.indexOf('IEMobile') !== -1);
    };
    
    
    // CODE MAIN ENTRY 	
    document.title = "$"+fname;
    
    // Get session code
    var preload = document.getElementById("usercode").innerHTML;
    
    // Check if available session code
    if(preload != "") {
        editor.session.setValue(atob(preload));        
        fname = window.location.pathname.split("$")[1];
    }
    
    ToolBar(); 
    
    // View only on mobile devices
    if(isMobile()) {
       // Viewer();
    }
    
</script>



